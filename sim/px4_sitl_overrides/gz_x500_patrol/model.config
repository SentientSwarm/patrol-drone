<?xml version="1.0"?>
<model>
  <name>gz_x500_patrol</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>patrol-drone</name>
    <email>noreply@patrol-drone.local</email>
  </author>
  <description>
    Camera-equipped variant of PX4's stock gz_x500 airframe (M5, SIM-3 / SIM-4 / OQ-7). Merges the
    upstream x500 model and adds a forward, slightly-down RGB camera that publishes the Phase 1 image
    topics. An override (not a PX4 fork, A2): selected at SITL launch via PX4_GZ_MODEL_NAME and
    GZ_SIM_RESOURCE_PATH pointed at sim/px4_sitl_overrides. The camera params (640x480 @ 15 Hz,
    hFOV ~1.2 rad, frame_id camera_link) are the 04/05 contract.
  </description>
</model>
