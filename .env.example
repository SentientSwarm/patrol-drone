# .env.example — documents the docker-compose build ARGs (docset 01-platform, C9 plumbing).
#
# These values are the SINGLE-SOURCE-OF-TRUTH pins from stack-manifest.toml. Do NOT hand-edit
# them here as the live values — generate the real, gitignored env file from the manifest so a
# pin change (e.g. OQ-3) flows through with no duplicated literal:
#
#   scripts/gen_build_args.py --env > .env.build
#   docker compose --env-file .env.build build sim dev
#
# We use a dedicated `.env.build` (not the compose-default `./.env`) on purpose: the repo-root
# `./.env` is gitignored and may hold secrets (e.g. LINEAR_API_KEY) unrelated to image builds.
# Passing `--env-file .env.build` keeps build args and secrets in separate files.
#
# The values below are illustrative (what the manifest currently resolves to) — they are NOT
# read by anything; `.env.build` is.
ROS_BASE_IMAGE=osrf/ros:jazzy-desktop@sha256:<digest-from-stack-manifest.toml>
PX4_VERSION=v1.17.0
PX4_COMMIT=d6f12ad1c4f70ad3230afd7d86e971421e02fef4
GZ_VERSION=harmonic
ROS_DISTRO=jazzy
XRCE_AGENT_SOURCE=https://github.com/eProsima/Micro-XRCE-DDS-Agent.git
XRCE_AGENT_VERSION=v3.0.1
XRCE_AGENT_COMMIT=155cfaaf8b7abac2e85d4a62d3649b09ace0be55
